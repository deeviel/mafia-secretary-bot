# ------------------------------------------------------------------------------
# Production Environment Configuration (e.g. for CloudPanel)
# ------------------------------------------------------------------------------

# NODE_ENV: Set to "production" to optimize Vite serving and performance.
NODE_ENV="production"

# PORT: The port the Node.js Express server runs on. CloudPanel reverse proxies to this port.
PORT="3000"

# DISCORD_TOKEN: Your Discord Bot Token (Go to https://discord.com/developers/applications)
DISCORD_TOKEN=""
